generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             BigInt         @id @default(autoincrement())
  nombre         String
  email          String         @unique
  passwordHash   String         @map("password_hash")
  rol            RolUsuario     @default(agente)
  avatarUrl      String?        @map("avatar_url")
  activo         Boolean        @default(true)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  contactos      Contacto[]
  conversaciones Conversacion[]
  eventos        Evento[]
  mensajes       Mensaje[]
  mensajes_grupo MensajeGrupo[]
  notas          Nota[]
  oportunidades  Oportunidad[]
  tareas         Tarea[]

  @@map("usuarios")
}

model Embudo {
  id            BigInt        @id @default(autoincrement())
  nombre        String
  descripcion   String?
  color         String        @default("#1E3A5F")
  orden         Int           @default(0)
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  etapas        Etapa[]
  oportunidades Oportunidad[]

  @@map("embudos")
}

model Etapa {
  id            BigInt        @id @default(autoincrement())
  embudoId      BigInt        @map("embudo_id")
  nombre        String
  color         String        @default("#94A3B8")
  orden         Int           @default(0)
  tipo          TipoEtapa     @default(normal)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  embudo        Embudo        @relation(fields: [embudoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  oportunidades Oportunidad[]

  @@index([embudoId, orden], map: "idx_etapas_embudo")
  @@map("etapas")
}

model Contacto {
  id             BigInt             @id @default(autoincrement())
  nombre         String
  telefono       String?            @unique
  email          String?
  empresa        String?
  avatarUrl      String?            @map("avatar_url")
  fuente         FuenteContacto     @default(manual)
  notas          String?
  responsableId  BigInt?            @map("responsable_id")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  etiquetas      ContactoEtiqueta[]
  responsable    Usuario?           @relation(fields: [responsableId], references: [id], onUpdate: NoAction)
  conversaciones Conversacion[]
  oportunidades  Oportunidad[]

  @@index([responsableId], map: "idx_contactos_responsable")
  @@map("contactos")
}

model Etiqueta {
  id        BigInt             @id @default(autoincrement())
  nombre    String             @unique
  color     String             @default("#B45309")
  contactos ContactoEtiqueta[]

  @@map("etiquetas")
}

model ContactoEtiqueta {
  contactoId BigInt   @map("contacto_id")
  etiquetaId BigInt   @map("etiqueta_id")
  contacto   Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([contactoId, etiquetaId])
  @@map("contacto_etiquetas")
}

model Oportunidad {
  id                  BigInt      @id @default(autoincrement())
  contactoId          BigInt      @map("contacto_id")
  embudoId            BigInt      @map("embudo_id")
  etapaId             BigInt      @map("etapa_id")
  titulo              String
  valor               Decimal     @default(0) @db.Decimal(12, 2)
  moneda              String      @default("MXN")
  responsableId       BigInt?     @map("responsable_id")
  orden               Int         @default(0)
  estado              EstadoOport @default(abierto)
  motivoPerdida       String?     @map("motivo_perdida")
  fechaCierreEstimada DateTime?   @map("fecha_cierre_estimada") @db.Date
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  closedAt            DateTime?   @map("closed_at") @db.Timestamptz(6)
  eventos             Evento[]
  notas               Nota[]
  contacto            Contacto    @relation(fields: [contactoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  embudo              Embudo      @relation(fields: [embudoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  etapa               Etapa       @relation(fields: [etapaId], references: [id], onUpdate: NoAction)
  responsable         Usuario?    @relation(fields: [responsableId], references: [id], onUpdate: NoAction)
  tareas              Tarea[]

  @@index([contactoId], map: "idx_oport_contacto")
  @@index([embudoId], map: "idx_oport_embudo")
  @@index([etapaId, orden], map: "idx_oport_etapa")
  @@map("oportunidades")
}

model CanalWhatsapp {
  id             BigInt         @id @default(autoincrement())
  nombre         String
  proveedor      ProveedorCanal @default(evolution)
  telefono       String?
  instancia      String?
  estado         EstadoCanal    @default(desconectado)
  config         Json           @default("{}")
  activo         Boolean        @default(true)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  bots           Bot[]
  conversaciones Conversacion[]
  grupos         Grupo[]

  @@map("canales_whatsapp")
}

model Grupo {
  id              BigInt         @id @default(autoincrement())
  canalId         BigInt?        @map("canal_id")
  jid             String         @unique
  nombre          String
  noLeidos        Int            @default(0) @map("no_leidos")
  ultimoMensajeAt DateTime?      @map("ultimo_mensaje_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  canal           CanalWhatsapp? @relation(fields: [canalId], references: [id], onUpdate: NoAction)
  mensajes        MensajeGrupo[]

  @@map("grupos")
}

model MensajeGrupo {
  id           BigInt       @id @default(autoincrement())
  grupoId      BigInt       @map("grupo_id")
  direccion    DireccionMsg
  tipo         TipoMsg      @default(texto)
  contenido    String?
  mediaUrl     String?      @map("media_url")
  mediaMime    String?      @map("media_mime")
  remitente    String?
  remitenteTel String?      @map("remitente_tel")
  status       StatusMsg    @default(enviado)
  waMessageId  String?      @unique @map("wa_message_id")
  enviadoPor   BigInt?      @map("enviado_por")
  timestamp    DateTime     @default(now()) @db.Timestamptz(6)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  usuarios     Usuario?     @relation(fields: [enviadoPor], references: [id], onUpdate: NoAction)
  grupo        Grupo        @relation(fields: [grupoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([grupoId, timestamp], map: "idx_msg_grupo")
  @@map("mensajes_grupo")
}

model Bot {
  id         BigInt         @id @default(autoincrement())
  nombre     String
  webhookUrl String         @map("webhook_url")
  apiToken   String         @unique @map("api_token")
  canalId    BigInt?        @map("canal_id")
  activo     Boolean        @default(true)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  canal      CanalWhatsapp? @relation(fields: [canalId], references: [id], onUpdate: NoAction)

  @@map("bots")
}

/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model Conversacion {
  id              BigInt         @id @default(autoincrement())
  contactoId      BigInt         @map("contacto_id")
  canalId         BigInt?        @map("canal_id")
  estado          EstadoConv     @default(abierta)
  responsableId   BigInt?        @map("responsable_id")
  noLeidos        Int            @default(0) @map("no_leidos")
  botActivo       Boolean        @default(true) @map("bot_activo")
  etiquetas       String[]       @default([])
  csatScore       Int?           @map("csat_score")
  csatEnviadoAt   DateTime?      @map("csat_enviado_at") @db.Timestamptz(6)
  avisoFueraAt    DateTime?      @map("aviso_fuera_at") @db.Timestamptz(6)
  ultimoMensajeAt DateTime?      @map("ultimo_mensaje_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  canal           CanalWhatsapp? @relation(fields: [canalId], references: [id], onUpdate: NoAction)
  contacto        Contacto       @relation(fields: [contactoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responsable     Usuario?       @relation(fields: [responsableId], references: [id], onUpdate: NoAction)
  mensajes        Mensaje[]

  @@unique([contactoId, canalId])
  @@index([ultimoMensajeAt(sort: Desc)], map: "idx_conv_orden")
  @@map("conversaciones")
}

model Mensaje {
  id             BigInt       @id @default(autoincrement())
  conversacionId BigInt       @map("conversacion_id")
  direccion      DireccionMsg
  tipo           TipoMsg      @default(texto)
  contenido      String?
  mediaUrl       String?      @map("media_url")
  mediaMime      String?      @map("media_mime")
  interna        Boolean      @default(false)
  status         StatusMsg    @default(enviado)
  waMessageId    String?      @unique @map("wa_message_id")
  enviadoPor     BigInt?      @map("enviado_por")
  timestamp      DateTime     @default(now()) @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario        Usuario?     @relation(fields: [enviadoPor], references: [id], onUpdate: NoAction)

  @@index([conversacionId, timestamp], map: "idx_msg_conv")
  @@map("mensajes")
}

model PlantillaMensaje {
  id        BigInt   @id @default(autoincrement())
  nombre    String
  contenido String
  categoria String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("plantillas_mensaje")
}

model Nota {
  id            BigInt      @id @default(autoincrement())
  oportunidadId BigInt      @map("oportunidad_id")
  usuarioId     BigInt?     @map("usuario_id")
  contenido     String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  oportunidad   Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario       Usuario?    @relation(fields: [usuarioId], references: [id], onUpdate: NoAction)

  @@map("notas")
}

model Tarea {
  id            BigInt       @id @default(autoincrement())
  oportunidadId BigInt?      @map("oportunidad_id")
  responsableId BigInt?      @map("responsable_id")
  titulo        String
  descripcion   String?
  venceAt       DateTime?    @map("vence_at") @db.Timestamptz(6)
  completada    Boolean      @default(false)
  completadaAt  DateTime?    @map("completada_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  oportunidad   Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responsable   Usuario?     @relation(fields: [responsableId], references: [id], onUpdate: NoAction)

  @@map("tareas")
}

model Ajustes {
  id                 BigInt   @id @default(autoincrement())
  autoAsignar        Boolean  @default(false) @map("auto_asignar")
  bienvenidaActiva   Boolean  @default(false) @map("bienvenida_activa")
  bienvenidaTexto    String?  @map("bienvenida_texto")
  crearLeadAuto      Boolean  @default(true) @map("crear_lead_auto")
  csatActivo         Boolean  @default(false) @map("csat_activo")
  csatTexto          String?  @map("csat_texto")
  horarioActivo      Boolean  @default(false) @map("horario_activo")
  horarioInicio      String?  @map("horario_inicio")
  horarioFin         String?  @map("horario_fin")
  horarioDias        String?  @map("horario_dias")
  fueraHorarioTexto  String?  @map("fuera_horario_texto")
  autoResolverActivo Boolean  @default(false) @map("auto_resolver_activo")
  autoResolverHoras  Int      @default(24) @map("auto_resolver_horas")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("ajustes")
}

model Evento {
  id            BigInt      @id @default(autoincrement())
  oportunidadId BigInt      @map("oportunidad_id")
  tipo          TipoEvento
  descripcion   String?
  usuarioId     BigInt?     @map("usuario_id")
  payload       Json        @default("{}")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  oportunidad   Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario       Usuario?    @relation(fields: [usuarioId], references: [id], onUpdate: NoAction)

  @@index([oportunidadId, createdAt], map: "idx_eventos_oport")
  @@map("eventos")
}

enum RolUsuario {
  admin
  agente

  @@map("rol_usuario")
}

enum TipoEtapa {
  normal
  ganado
  perdido

  @@map("tipo_etapa")
}

enum EstadoOport {
  abierto
  ganado
  perdido

  @@map("estado_oport")
}

enum FuenteContacto {
  whatsapp
  manual
  meta_ads
  web
  otro

  @@map("fuente_contacto")
}

enum EstadoConv {
  abierta
  pendiente
  cerrada

  @@map("estado_conv")
}

enum DireccionMsg {
  entrante
  saliente

  @@map("direccion_msg")
}

enum TipoMsg {
  texto
  imagen
  audio
  video
  documento
  ubicacion
  plantilla

  @@map("tipo_msg")
}

enum StatusMsg {
  pendiente
  enviado
  entregado
  leido
  fallido

  @@map("status_msg")
}

enum ProveedorCanal {
  evolution
  cloud_api

  @@map("proveedor_canal")
}

enum EstadoCanal {
  conectado
  desconectado

  @@map("estado_canal")
}

enum TipoEvento {
  creada
  etapa_cambio
  ganada
  perdida
  nota
  tarea
  mensaje
  asignacion

  @@map("tipo_evento")
}
