generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  admin
  agente

  @@map("rol_usuario")
}

enum TipoEtapa {
  normal
  ganado
  perdido

  @@map("tipo_etapa")
}

enum EstadoOport {
  abierto
  ganado
  perdido

  @@map("estado_oport")
}

enum FuenteContacto {
  whatsapp
  manual
  meta_ads
  web
  otro

  @@map("fuente_contacto")
}

enum EstadoConv {
  abierta
  pendiente
  cerrada

  @@map("estado_conv")
}

enum DireccionMsg {
  entrante
  saliente

  @@map("direccion_msg")
}

enum TipoMsg {
  texto
  imagen
  audio
  video
  documento
  ubicacion
  plantilla

  @@map("tipo_msg")
}

enum StatusMsg {
  pendiente
  enviado
  entregado
  leido
  fallido

  @@map("status_msg")
}

enum ProveedorCanal {
  evolution
  cloud_api

  @@map("proveedor_canal")
}

enum EstadoCanal {
  conectado
  desconectado

  @@map("estado_canal")
}

enum TipoEvento {
  creada
  etapa_cambio
  ganada
  perdida
  nota
  tarea
  mensaje
  asignacion

  @@map("tipo_evento")
}

model Usuario {
  id           BigInt      @id @default(autoincrement())
  nombre       String
  email        String      @unique
  passwordHash String      @map("password_hash")
  rol          RolUsuario  @default(agente)
  avatarUrl    String?     @map("avatar_url")
  activo       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")

  contactos      Contacto[]
  oportunidades  Oportunidad[]
  conversaciones Conversacion[]
  mensajes       Mensaje[]
  notas          Nota[]
  tareas         Tarea[]
  eventos        Evento[]

  @@map("usuarios")
}

model Embudo {
  id          BigInt   @id @default(autoincrement())
  nombre      String
  descripcion String?
  color       String   @default("#1E3A5F")
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  etapas        Etapa[]
  oportunidades Oportunidad[]

  @@map("embudos")
}

model Etapa {
  id        BigInt    @id @default(autoincrement())
  embudoId  BigInt    @map("embudo_id")
  nombre    String
  color     String    @default("#94A3B8")
  orden     Int       @default(0)
  tipo      TipoEtapa @default(normal)
  createdAt DateTime  @default(now()) @map("created_at")

  embudo        Embudo        @relation(fields: [embudoId], references: [id], onDelete: Cascade)
  oportunidades Oportunidad[]

  @@index([embudoId, orden])
  @@map("etapas")
}

model Contacto {
  id            BigInt         @id @default(autoincrement())
  nombre        String
  telefono      String?        @unique
  email         String?
  empresa       String?
  avatarUrl     String?        @map("avatar_url")
  fuente        FuenteContacto @default(manual)
  notas         String?
  responsableId BigInt?        @map("responsable_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")

  responsable    Usuario?           @relation(fields: [responsableId], references: [id], onDelete: SetNull)
  etiquetas      ContactoEtiqueta[]
  oportunidades  Oportunidad[]
  conversaciones Conversacion[]

  @@index([responsableId])
  @@map("contactos")
}

model Etiqueta {
  id     BigInt @id @default(autoincrement())
  nombre String @unique
  color  String @default("#B45309")

  contactos ContactoEtiqueta[]

  @@map("etiquetas")
}

model ContactoEtiqueta {
  contactoId BigInt @map("contacto_id")
  etiquetaId BigInt @map("etiqueta_id")

  contacto Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  etiqueta Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([contactoId, etiquetaId])
  @@map("contacto_etiquetas")
}

model Oportunidad {
  id                  BigInt       @id @default(autoincrement())
  contactoId          BigInt       @map("contacto_id")
  embudoId            BigInt       @map("embudo_id")
  etapaId             BigInt       @map("etapa_id")
  titulo              String
  valor               Decimal      @default(0) @db.Decimal(12, 2)
  moneda              String       @default("MXN")
  responsableId       BigInt?      @map("responsable_id")
  orden               Int          @default(0)
  estado              EstadoOport  @default(abierto)
  motivoPerdida       String?      @map("motivo_perdida")
  fechaCierreEstimada DateTime?    @map("fecha_cierre_estimada") @db.Date
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at")
  closedAt            DateTime?    @map("closed_at")

  contacto    Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  embudo      Embudo   @relation(fields: [embudoId], references: [id], onDelete: Cascade)
  etapa       Etapa    @relation(fields: [etapaId], references: [id], onDelete: Restrict)
  responsable Usuario? @relation(fields: [responsableId], references: [id], onDelete: SetNull)
  notas       Nota[]
  tareas      Tarea[]
  eventos     Evento[]

  @@index([etapaId, orden])
  @@index([embudoId])
  @@index([contactoId])
  @@map("oportunidades")
}

model CanalWhatsapp {
  id        BigInt         @id @default(autoincrement())
  nombre    String
  proveedor ProveedorCanal @default(evolution)
  telefono  String?
  instancia String?
  estado    EstadoCanal    @default(desconectado)
  config    Json           @default("{}")
  activo    Boolean        @default(true)
  createdAt DateTime       @default(now()) @map("created_at")

  conversaciones Conversacion[]
  bots           Bot[]
  grupos         Grupo[]

  @@map("canales_whatsapp")
}

// Grupos de WhatsApp: bandeja aparte, NO son leads (no entran al embudo/CSAT/contactos).
model Grupo {
  id              BigInt    @id @default(autoincrement())
  canalId         BigInt?   @map("canal_id")
  jid             String    @unique
  nombre          String
  noLeidos        Int       @default(0) @map("no_leidos")
  ultimoMensajeAt DateTime? @map("ultimo_mensaje_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  canal    CanalWhatsapp? @relation(fields: [canalId], references: [id], onDelete: SetNull)
  mensajes MensajeGrupo[]

  @@map("grupos")
}

model MensajeGrupo {
  id           BigInt       @id @default(autoincrement())
  grupoId      BigInt       @map("grupo_id")
  direccion    DireccionMsg
  tipo         TipoMsg      @default(texto)
  contenido    String?
  mediaUrl     String?      @map("media_url")
  mediaMime    String?      @map("media_mime")
  remitente    String?      // nombre de quien escribió en el grupo
  remitenteTel String?      @map("remitente_tel")
  status       StatusMsg    @default(enviado)
  waMessageId  String?      @unique @map("wa_message_id")
  enviadoPor   BigInt?      @map("enviado_por")
  timestamp    DateTime     @default(now())
  createdAt    DateTime     @default(now()) @map("created_at")

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@index([grupoId, timestamp])
  @@map("mensajes_grupo")
}

// Bot estilo "Agent Bot" de Chatwoot: webhook saliente (CRM->n8n) + token para responder (n8n->CRM).
model Bot {
  id         BigInt   @id @default(autoincrement())
  nombre     String
  webhookUrl String   @map("webhook_url")     // n8n: el CRM le manda los mensajes entrantes
  apiToken   String   @unique @map("api_token") // n8n: autentica de vuelta con header api_access_token
  canalId    BigInt?  @map("canal_id")          // null = aplica a todos los canales
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  canal CanalWhatsapp? @relation(fields: [canalId], references: [id], onDelete: SetNull)

  @@map("bots")
}

model Conversacion {
  id              BigInt      @id @default(autoincrement())
  contactoId      BigInt      @map("contacto_id")
  canalId         BigInt?     @map("canal_id")
  estado          EstadoConv  @default(abierta)
  responsableId   BigInt?     @map("responsable_id")
  noLeidos        Int         @default(0) @map("no_leidos")
  botActivo       Boolean     @default(true) @map("bot_activo")
  etiquetas       String[]    @default([])
  csatScore       Int?        @map("csat_score")
  csatEnviadoAt   DateTime?   @map("csat_enviado_at")
  avisoFueraAt    DateTime?   @map("aviso_fuera_at")
  ultimoMensajeAt DateTime?   @map("ultimo_mensaje_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  contacto    Contacto       @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  canal       CanalWhatsapp? @relation(fields: [canalId], references: [id], onDelete: SetNull)
  responsable Usuario?       @relation(fields: [responsableId], references: [id], onDelete: SetNull)
  mensajes    Mensaje[]

  @@unique([contactoId, canalId])
  @@index([ultimoMensajeAt])
  @@map("conversaciones")
}

model Mensaje {
  id             BigInt        @id @default(autoincrement())
  conversacionId BigInt        @map("conversacion_id")
  direccion      DireccionMsg
  tipo           TipoMsg       @default(texto)
  contenido      String?
  mediaUrl       String?       @map("media_url")
  mediaMime      String?       @map("media_mime")
  interna        Boolean       @default(false)
  esDifusion     Boolean       @default(false) @map("es_difusion")
  status         StatusMsg     @default(enviado)
  waMessageId    String?       @unique @map("wa_message_id")
  enviadoPor     BigInt?       @map("enviado_por")
  timestamp      DateTime      @default(now())
  createdAt      DateTime      @default(now()) @map("created_at")

  conversacion Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [enviadoPor], references: [id], onDelete: SetNull)

  @@index([conversacionId, timestamp])
  @@map("mensajes")
}

model PlantillaMensaje {
  id        BigInt   @id @default(autoincrement())
  nombre    String
  contenido String
  categoria String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("plantillas_mensaje")
}

model Nota {
  id            BigInt   @id @default(autoincrement())
  oportunidadId BigInt   @map("oportunidad_id")
  usuarioId     BigInt?  @map("usuario_id")
  contenido     String
  createdAt     DateTime @default(now()) @map("created_at")

  oportunidad Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)
  usuario     Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("notas")
}

model Tarea {
  id            BigInt    @id @default(autoincrement())
  oportunidadId BigInt?   @map("oportunidad_id")
  responsableId BigInt?   @map("responsable_id")
  titulo        String
  descripcion   String?
  venceAt       DateTime? @map("vence_at")
  completada    Boolean   @default(false)
  completadaAt  DateTime? @map("completada_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  oportunidad Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)
  responsable Usuario?     @relation(fields: [responsableId], references: [id], onDelete: SetNull)

  @@index([responsableId, venceAt])
  @@map("tareas")
}

model Ajustes {
  id               BigInt   @id @default(autoincrement())
  autoAsignar      Boolean  @default(false) @map("auto_asignar")
  bienvenidaActiva Boolean  @default(false) @map("bienvenida_activa")
  bienvenidaTexto  String?  @map("bienvenida_texto")
  crearLeadAuto    Boolean  @default(true) @map("crear_lead_auto")
  // CSAT
  csatActivo       Boolean  @default(false) @map("csat_activo")
  csatTexto        String?  @map("csat_texto")
  // Horario de atención
  horarioActivo    Boolean  @default(false) @map("horario_activo")
  horarioInicio    String?  @map("horario_inicio")  // "09:00"
  horarioFin       String?  @map("horario_fin")     // "18:00"
  horarioDias      String?  @map("horario_dias")    // "1,2,3,4,5" (1=lunes)
  fueraHorarioTexto String? @map("fuera_horario_texto")
  // Auto-resolver
  autoResolverActivo Boolean @default(false) @map("auto_resolver_activo")
  autoResolverHoras  Int     @default(24) @map("auto_resolver_horas")
  // IA
  nombreNegocio    String?  @map("nombre_negocio")
  iaPromptSistema  String?  @map("ia_prompt_sistema")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("ajustes")
}

model Evento {
  id            BigInt     @id @default(autoincrement())
  oportunidadId BigInt     @map("oportunidad_id")
  tipo          TipoEvento
  descripcion   String?
  usuarioId     BigInt?    @map("usuario_id")
  payload       Json       @default("{}")
  createdAt     DateTime   @default(now()) @map("created_at")

  oportunidad Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)
  usuario     Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([oportunidadId, createdAt])
  @@map("eventos")
}
